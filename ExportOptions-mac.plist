<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mac Catalyst App Store upload. exportArchive produces a signed .pkg    -->
    <!-- that altool uploads with --type macos. Same bundle id as iOS          -->
    <!-- (Universal Purchase). Automatic signing selects the distribution +    -->
    <!-- Mac installer certs from the local Keychain.                          -->
    <key>method</key>
    <string>app-store-connect</string>
    <key>teamID</key>
    <string>FZ5HL2XU6U</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>uploadSymbols</key>
    <true/>
</dict>
</plist>
